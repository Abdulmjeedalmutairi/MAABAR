{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "e2e/.tsbuild",
    "baseUrl": ".",
    "paths": {
      "@e2e/*": ["e2e/*"]
    }
  },
  "include": [
    "playwright.config.ts",
    "e2e/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "src",
    "build"
  ]
}
