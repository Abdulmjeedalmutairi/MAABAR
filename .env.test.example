# ─── Playwright E2E test environment ─────────────────────────────────────────
# Copy this file to .env.test and fill in the real values.
# NEVER commit .env.test to version control.

# Supabase service-role key — used ONLY in globalSetup/globalTeardown and
# fixture helpers running in Node.js (never loaded into the browser bundle).
# Find it in: Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Base URL — use https://maabar.io for production tests, http://localhost:3000 for local
PLAYWRIGHT_BASE_URL=https://maabar.io

# ─── Admin credentials for Scenario 6 (admin approval flow) ──────────────────
MAABAR_ADMIN_EMAIL=admin@maabar.io
MAABAR_ADMIN_PASSWORD=your-admin-password-here

# ─── Optional: override Supabase project URL ─────────────────────────────────
# Leave blank to use the hardcoded value from supabase.js
# SUPABASE_URL=https://utzalmszfqfcofywfetv.supabase.co
